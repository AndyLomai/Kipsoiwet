1 0 0 1 50 742 Tm (# Kipsoiwet Bot Instructions \(Consolidated\)) Tj
1 0 0 1 50 728 Tm () Tj
1 0 0 1 50 714 Tm (## Trading Method Rules) Tj
1 0 0 1 50 700 Tm (- Use Polymarket price model: odds = 1 / price.) Tj
1 0 0 1 50 686 Tm (- Profit multiplier for stake sizing: \(1 / p\) - 1.) Tj
1 0 0 1 50 672 Tm (- Martingale stake formula:) Tj
1 0 0 1 50 658 Tm (  stake = \(cumulative_losses + target_profit\) / \(\(1 / p\) - 1\)) Tj
1 0 0 1 50 644 Tm (- Default target profit per completed cycle: 1 USD.) Tj
1 0 0 1 50 630 Tm (- Bet execution window: within first 3 seconds of candle \(latency-tolerant\).) Tj
1 0 0 1 50 616 Tm (- If a round loses, cumulative losses are added and next stake is recalculated.) Tj
1 0 0 1 50 602 Tm (- Keep trading using the predetermined sequence until a win.) Tj
1 0 0 1 50 588 Tm (- After a win, cumulative losses reset and stake sizing restarts from the base formula.) Tj
1 0 0 1 50 574 Tm () Tj
1 0 0 1 50 560 Tm (## Setup) Tj
1 0 0 1 50 546 Tm (1. Clone repository:) Tj
1 0 0 1 50 532 Tm (   git clone https://github.com/AndyLomai/Kipsoiwet.git) Tj
1 0 0 1 50 518 Tm (   cd Kipsoiwet) Tj
1 0 0 1 50 504 Tm (2. Create virtual environment:) Tj
1 0 0 1 50 490 Tm (   python3.11 -m venv .venv) Tj
1 0 0 1 50 476 Tm (   source .venv/bin/activate) Tj
1 0 0 1 50 462 Tm (3. Install dependencies:) Tj
1 0 0 1 50 448 Tm (   pip install -e ".[dev]") Tj
1 0 0 1 50 434 Tm () Tj
1 0 0 1 50 420 Tm (## Environment Configuration \(.env\)) Tj
1 0 0 1 50 406 Tm (TELEGRAM_BOT_TOKEN=your_bot_token) Tj
1 0 0 1 50 392 Tm (POLYMARKET_EVENT_SLUG=bitcoin-up-or-down-march-31-11am-et) Tj
1 0 0 1 50 378 Tm (TARGET_PROFIT_USD=1.0) Tj
1 0 0 1 50 364 Tm (BET_WINDOW_SECONDS=3.0) Tj
1 0 0 1 50 350 Tm (INITIAL_SIDE=UP) Tj
1 0 0 1 50 336 Tm (DRY_RUN=true) Tj
1 0 0 1 50 322 Tm () Tj
1 0 0 1 50 308 Tm () Tj
1 0 0 1 50 294 Tm (## Run on a PC \(direct\)) Tj
1 0 0 1 50 280 Tm () Tj
1 0 0 1 50 266 Tm (### Windows \(Command Prompt / cmd\)) Tj
1 0 0 1 50 252 Tm (cd Kipsoiwet) Tj
1 0 0 1 50 238 Tm (py -3.11 -m venv .venv) Tj
1 0 0 1 50 224 Tm (.venv\\Scripts\\activate.bat) Tj
1 0 0 1 50 210 Tm (pip install -e ".[dev]") Tj
1 0 0 1 50 196 Tm (set TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN) Tj
1 0 0 1 50 182 Tm (python -m kipsoiwet_bot) Tj
1 0 0 1 50 168 Tm () Tj
1 0 0 1 50 154 Tm (### macOS / Linux) Tj
1 0 0 1 50 140 Tm (cd Kipsoiwet) Tj
1 0 0 1 50 126 Tm (python3.11 -m venv .venv) Tj
1 0 0 1 50 112 Tm (source .venv/bin/activate) Tj
1 0 0 1 50 98 Tm (pip install -e ".[dev]") Tj
1 0 0 1 50 84 Tm (export TELEGRAM_BOT_TOKEN='YOUR_BOT_TOKEN') Tj
1 0 0 1 50 70 Tm (python -m kipsoiwet_bot) Tj
ET
endstream
